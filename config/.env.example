# AAA AI Automation example environment.
# Copy to a local environment file outside Git tracking and replace placeholder values.

APP_ENV=development
APP_BASE_URL=http://localhost

POSTGRES_DB=aaa_automation
POSTGRES_USER=aaa_automation
POSTGRES_PASSWORD=replace-with-local-secret
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_ENCRYPTION_KEY=replace-with-local-secret

AI_PROVIDER=replace-with-provider-name
AI_API_KEY=replace-with-local-secret

SMTP_HOST=replace-with-smtp-host
SMTP_PORT=587
SMTP_USER=replace-with-smtp-user
SMTP_PASSWORD=replace-with-local-secret
NOTIFICATION_FROM=replace-with-sender@example.com
OPERATOR_NOTIFICATION_TO=replace-with-operator@example.com

BACKUP_TARGET=/mnt/storage/aaa-ai-automation
LOG_LEVEL=info
